# ============================================================
#  Service pont MinIO -> Airflow
#  Recoit les notifications MinIO et declenche le DAG d'ingestion.
# ============================================================

FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi==0.111.0 uvicorn==0.29.0 httpx==0.27.0

COPY minio_airflow_bridge.py /app/minio_airflow_bridge.py

EXPOSE 8500

CMD ["uvicorn", "minio_airflow_bridge:app", "--host", "0.0.0.0", "--port", "8500"]
