-- ============================================================
-- cartes_snapshot — Historisation des cartes VALIDES (SCD Type 2)
-- Al Barid Bank — Data Quality Platform
--
-- Seules les cartes validees sont historisees ; les rejetees sont exclues.
-- dbt suit l'evolution du statut de la carte (active -> expiree -> bloquee)
-- et versionne chaque changement.
-- ============================================================

with rejected as (
    select record_id
    from "barid_bank"."public"."admin_decisions"
    where table_name = 'cartes' and decision = 'rejected'
)

select
    ca.carte_id,
    ca.compte_id,
    ca.type_carte,
    ca.date_expiration,
    ca.statut
from "barid_bank"."public"."cartes" ca
where ca.carte_id not in (select record_id from rejected)


    ),

    snapshotted_data as (

        select *, 
    
        carte_id as dbt_unique_key
    

        from "barid_bank"."dwh_metier"."cartes_snapshot"
        where
            
                dbt_valid_to is null
            

    ),

    insertions_source_data as (

        select *, 
    
        carte_id as dbt_unique_key
    
,
            now()::timestamp without time zone as dbt_updated_at,
            now()::timestamp without time zone as dbt_valid_from,
            
  
  coalesce(nullif(now()::timestamp without time zone, now()::timestamp without time zone), null)
  as dbt_valid_to
,
            md5(coalesce(cast(carte_id as varchar ), '')
         || '|' || coalesce(cast(now()::timestamp without time zone as varchar ), '')
        ) as dbt_scd_id

        from snapshot_query
    ),

    updates_source_data as (

        select *, 
    
        carte_id as dbt_unique_key
    
,
            now()::timestamp without time zone as dbt_updated_at,
            now()::timestamp without time zone as dbt_valid_from,
            now()::timestamp without time zone as dbt_valid_to

        from snapshot_query
    ),

    deletes_source_data as (

        select *, 
    
        carte_id as dbt_unique_key
    

        from snapshot_query
    ),
    

    insertions as (

        select
            'insert' as dbt_change_type,
            source_data.*

        from insertions_source_data as source_data
        left outer join snapshotted_data
            on 
    
        snapshotted_data.dbt_unique_key = source_data.dbt_unique_key
    

            where 
    
        snapshotted_data.dbt_unique_key is null
    

            or (
    
        snapshotted_data.dbt_unique_key is not null
    
 and ((snapshotted_data."statut" != source_data."statut"
        or
        (
            ((snapshotted_data."statut" is null) and not (source_data."statut" is null))
            or
            ((not snapshotted_data."statut" is null) and (source_data."statut" is null))
        ) or snapshotted_data."type_carte" != source_data."type_carte"
        or
        (
            ((snapshotted_data."type_carte" is null) and not (source_data."type_carte" is null))
            or
            ((not snapshotted_data."type_carte" is null) and (source_data."type_carte" is null))
        ) or snapshotted_data."date_expiration" != source_data."date_expiration"
        or
        (
            ((snapshotted_data."date_expiration" is null) and not (source_data."date_expiration" is null))
            or
            ((not snapshotted_data."date_expiration" is null) and (source_data."date_expiration" is null))
        ) or snapshotted_data."compte_id" != source_data."compte_id"
        or
        (
            ((snapshotted_data."compte_id" is null) and not (source_data."compte_id" is null))
            or
            ((not snapshotted_data."compte_id" is null) and (source_data."compte_id" is null))
        )))

        )

    ),

    updates as (

        select
            'update' as dbt_change_type,
            source_data.*,
            snapshotted_data.dbt_scd_id

        from updates_source_data as source_data
        join snapshotted_data
            on 
    
        snapshotted_data.dbt_unique_key = source_data.dbt_unique_key
    

