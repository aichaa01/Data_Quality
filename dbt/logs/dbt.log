  create  table "barid_bank"."public_marts"."dim_clients__dbt_tmp"
  
  
    as
  
  (
    with clients as (
    select * from "barid_bank"."public_staging"."stg_clients"
),
agences as (
    select * from "barid_bank"."public_staging"."stg_agences"
),
deduped as (
    select distinct on (client_id) *
    from clients
    order by client_id, date_creation desc
)

select
    d.client_id, d.cin, d.nom, d.prenom, d.date_naissance,
    d.telephone, d.email, d.adresse, d.date_creation,
    d.agence_id, a.nom_agence, a.ville, a.region,
    a.statut                                    as statut_agence,
    d.email_manquant, d.telephone_manquant, d.adresse_manquante,
    d.email_invalide, d.telephone_invalide,
    case when a.statut = 'fermée' then true
         else false end                         as agence_fermee,
    100
    - case when d.email_manquant     then 15 else 0 end
    - case when d.telephone_manquant then 10 else 0 end
    - case when d.adresse_manquante  then 10 else 0 end
    - case when d.email_invalide     then 20 else 0 end
    - case when d.telephone_invalide then 15 else 0 end
    - case when a.statut = 'fermée'  then 30 else 0 end
                                                as dq_score
from deduped d
left join agences a on d.agence_id = a.agence_id
  );
  
