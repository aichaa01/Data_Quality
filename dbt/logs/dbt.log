-- ============================================================

with rejected as (
    select record_id
    from "barid_bank"."public"."admin_decisions"
    where table_name = 'clients' and decision = 'rejected'
)

select
    cl.client_id,
    cl.cin,
    cl.nom,
    cl.prenom,
    cl.date_naissance,
    cl.telephone,
    cl.email,
